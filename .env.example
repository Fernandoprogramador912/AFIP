# Copiar a .env y completar valores reales (no commitear .env)

# mock = datos simulados locales; live = WSAA + SOAP real (homologación o producción)
ARCA_MODE=mock
# Diagnóstico: `tasa-arca doctor` (rutas, WSAA, WSDL; sin contraseña). Ver docs/afip_runbook_diagnostico.md

# CUIT de la empresa (11 dígitos, sin guiones)
ARCA_CUIT=20123456789

# Certificado digital (.p12) y clave — solo necesario en ARCA_MODE=live
ARCA_CERT_PATH=C:/ruta/al/certificado.p12
ARCA_CERT_PASSWORD=

# Servicio WSAA a autorizar (debe coincidir con el WS de negocio que consuman en ARCA)
# Ejemplo documental; confirmar en documentación del WS elegido.
ARCA_WSAA_SERVICE=wsaduanas

# Homologación WSAA (default) o producción: https://wsaa.afip.gov.ar/ws/services/LoginCms
ARCA_WSAA_URL=https://wsaahomo.afip.gov.ar/ws/services/LoginCms

# Algoritmo de hash para firma CMS (sha256 recomendado si el certificado lo admite)
ARCA_WSAA_HASH=sha256
# auto = hora del TRA desde cabecera Date de AFIP (si el PC tiene mal el año); local | http
ARCA_WSAA_TIME_SOURCE=auto

# WSDL del web service de liquidaciones (obligatorio en live)
ARCA_LIQUIDACIONES_WSDL=

# Si el WSDL de arriba es MOA (wconsdeclaracion), opcional: segundo WSDL con consultarLiquidaciones
# (por CUIT + fechas, sin listar D.I.). Completá con la URL que te dé ARCA/AFIP para ese servicio;
# es un dato por entorno (homologación/producción), no por cliente. Fusiona resultados con MOA.
# ARCA_LIQUIDACIONES_COMPLEMENTO_WSDL=

# Operación SOAP (nombre en el WSDL)
ARCA_LIQUIDACIONES_METHOD=consultarLiquidaciones

# Namespace para Token/Sign en Header (ajustar según WSDL de ARCA)
ARCA_SOAP_AUTH_NS=http://ar.gov.afip.dif.afip/

# MOA (wconsdeclaracion): códigos cortos IMEX (el texto largo del combo web suele dar error 42075 longitud inválida)
ARCA_MOA_TIPO_AGENTE=IMEX
ARCA_MOA_ROL=IMEX
# both = DetalladaListaDeclaraciones + SimiDjaiListaDeclaraciones (grilla SIMI como en MOA web)
ARCA_MOA_LISTA_FUENTE=both
# minimal = cuit_11 + cuit_11_TODOS (2 consultas por fuente); auto = también CANC
ARCA_MOA_LISTA_VARIANTES=minimal
# Si AFIP no devuelve algunos D.I. en el listado, forzá el detalle MOA (separados por coma).
# Tras fetch, las fechas se toman de carátula/detalle para que entren en el filtro por año.
# ARCA_MOA_DESTINACION_IDS_EXTRA=25001IC...,25001IC...
# Pausa entre llamadas al mismo método MOA con el mismo CUIT (tramos de 30d, variantes, declaraciones).
# AFIP exige ≥25s (error 6013). Default 26 (1s de margen); subir si igual aparece 6013.
ARCA_MOA_CHUNK_SLEEP_SECONDS=26
# Pausa base antes de reintentar una llamada con 6013. AFIP pide ≥25s por método/CUIT.
ARCA_MOA_RETRY_6013_SLEEP_SECONDS=26

# Rutas locales
ARCA_DATA_DIR=data
ARCA_SQLITE_PATH=data/tasa_estadistica.db
ARCA_TICKET_PATH=data/ta.xml
ARCA_EXCEL_OUTPUT=out/tasa_estadistica_auditoria.xlsx

# CodigoConcepto que AFIP informa como Tasa de estadística en liquidación detallada (validar con PDF / RG 632)
ARCA_TASA_ESTADISTICA_CODIGOS=TE,011

# Período analítico: no consultar fechas anteriores (fecha de liquidación); default 2019-01-01
# TASA_ANALISIS_DESDE=2019-01-01
# Si true, rechaza «hasta» posterior a hoy (panel/API/CLI)
# TASA_ANALISIS_HASTA_MAX_HOY=true

# Permitir iniciar descarga AFIP desde el panel (POST /api/fetch). false = solo CLI.
# TASA_PANEL_FETCH_ENABLED=true

# Recupero / panel: subcadenas en destinacion_id que cuentan como import (OR). Default IC.
# Para incluir otros códigos AFIP: IC,XXX (ojo: «IM» coincide dentro de «SIM» — falsos positivos).
# TASA_RECUPERO_DESTINACION_SUBCADENAS=IC
